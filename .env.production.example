# ============================================
# BlueStay Production Environment Variables
# ============================================
# Copy this file to .env.production and fill in real values
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# ============================================
# Database
# ============================================
POSTGRES_USER=bluestay
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=bluestay

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_RANDOM_64_CHAR
JWT_EXPIRES_IN=15m

# ============================================
# CORS (comma-separated allowed origins)
# ============================================
CORS_ORIGINS=https://bluestay.in,https://www.bluestay.in,https://admin.bluestay.in

# ============================================
# Public URLs (used during build)
# ============================================
NEXT_PUBLIC_API_URL=https://api.bluestay.in/graphql
NEXT_PUBLIC_SITE_URL=https://bluestay.in

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@bluestay.in
SMTP_PASS=
SMTP_FROM=BlueStay <noreply@bluestay.in>

# ============================================
# Payment Gateways
# ============================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY=

# ============================================
# Domain Configuration
# ============================================
# Primary aggregator domain
AGGREGATOR_DOMAIN=bluestay.in
# API subdomain
API_DOMAIN=api.bluestay.in

# ============================================
# Google OAuth (optional)
# ============================================
# Get from console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.bluestay.in/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ============================================
# Web Push Notifications (optional)
# ============================================
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bluestay.in
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ============================================
# SMS / WhatsApp via MSG91 (optional)
# ============================================
MSG91_AUTH_KEY=
MSG91_SENDER_ID=BSTAY
MSG91_TEMPLATE_ID=
MSG91_WHATSAPP_FROM=

# ============================================
# File Storage (default: local)
# ============================================
# Set to "s3" for cloud storage (AWS S3 or Cloudflare R2)
UPLOAD_PROVIDER=local
S3_BUCKET=
S3_REGION=ap-south-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ============================================
# S3 Backup Bucket (optional)
# ============================================
S3_BACKUP_BUCKET=

# ============================================
# Error Tracking — Sentry (optional)
# ============================================
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ============================================
# Analytics (optional)
# ============================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
